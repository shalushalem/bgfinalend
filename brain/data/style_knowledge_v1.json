  "principles": {
    "goals": {
      "balance": "Create balance between upper and lower proportions.",
      "define_waist": "Optional. Use when user wants shape/definition.",
      "elongate": "Use vertical lines, tonal looks, higher rises, clean hems.",
      "soften": "Use drape, rounded necklines, softer fabrics to reduce sharpness.",
      "structure": "Use tailoring, shoulder seams, and crisp fabrics to add shape."
    },
    "universal_rules": [
      "Place brighter colors where the user wants focus.",
      "Tonal/monochrome outfits elongate and look premium.",
      "High contrast draws attention; low contrast feels sleek.",
      "Near-face colors matter most (tops, collars, scarves, earrings).",
      "Fit beats trends: shoulder seam, rise, hem length, and fabric quality matter most."
    ],
    "stylist_output_format": [
      "Give 2–3 outfit routes (safe, elevated, bold).",
      "Always include shoes + bag (or belt/watch for men) + 1–2 accessories.",
      "Mention fit notes (rise, length, neckline, jacket length)."
    ]
  },

