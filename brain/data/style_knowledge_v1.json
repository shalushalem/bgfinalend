  "_comment": "AHVI Style Knowledge v1 (Women + Men). Fashion intelligence (rules + recos). Not chat copy. Use with user profile (gender, body_type, height_bucket, proportions, undertone, style_vibe, fit_preference, occasion, weather).",

  "meta": {
    "version": "1.0.0",
