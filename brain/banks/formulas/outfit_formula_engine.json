{
  "outfit_formula_engine_v1": {
    "version": "1.0",
    "description": "Reusable outfit formulas for AHVI styling options. Gender_identity influences defaults but never restricts. Use wardrobe inventory + constraints first, then formulas.",
    "selection_policy": {
      "priority_order": [
        "wardrobe_inventory",
        "explicit_user_constraints",
        "occasion_context",
        "weather_context",
        "personal_style_memory",
        "gender_defaults",
        "cohort_tone"
      ],
      "defaults": {
        "options_count": 3,
        "max_options": 3,
        "option_balance_rule": "2_safe_1_bolder_if_allowed",
        "bolder_option_allowed_if": [
          "user_requests_bold",
          "user_style_profile_allows_bold"
        ]
      },
      "constraints_supported": [
        "no_heels",
        "comfortable",
        "modest",
        "hot_weather",
        "rainy_weather",
        "budget_cap",
        "only_from_wardrobe",
        "no_tight_clothes",
        "no_short_hems",
        "all_black",
        "minimal",
        "bold",
        "no_jewelry"
      ],
      "ban_rules": [
        "Never recommend body-shaming or appearance-negating language.",
        "Never block items solely based on gender_identity."
      ]
    },

    "style_axes": {
      "energy": ["minimal", "classic", "romantic", "street", "bold", "sporty", "elevated"],
      "formality": ["very_casual", "casual", "smart_casual", "semi_formal", "formal"],
      "silhouette": ["relaxed", "balanced", "structured", "fluid"],
      "color_story": ["neutral", "monochrome", "soft_tones", "high_contrast", "jewel_tones", "earthy"]
    },

