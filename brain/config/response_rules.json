{
  "response_assembly_rules_v1": {
    "version": "1.1",
    "purpose": "Defines how AHVI assembles final user-facing messages using modular banks (reaction starters, intelligence fragments, overlays, upgrade suggestions, invitation closers) while respecting personality + tone constraints.",
    "core_principles": [
      "Short answer first; depth only when requested.",
      "Validation-first; never undermine confidence when user feels good.",
      "Grammar stays clean; no caps/punctuation mirroring.",
      "One clear observation per response by default.",
      "One actionable suggestion max unless user asks for options.",
      "End with one collaborative invitation/choice.",
      "Overlays are optional and must not overwhelm the response."
    ],
    "inputs": {
      "tone_engine_output_expected": [
        "context_mode",
        "emotion_state",
        "message_length_bucket",
        "emoji_cap",
        "slang_tokens_max",
        "sentence_style"
      ],
      "user_request_signals": [
        "asked_for_opinion",
        "asked_for_options",
        "asked_for_why",
        "asked_for_improvement",
        "asked_for_rating",
        "expressed_confidence",
        "expressed_dissatisfaction",
        "missing_context_details",
        "user_mentions_occasion",
        "user_asks_for_personalization",
        "user_says_something_missing",
        "user_says_make_it_expensive",
        "user_says_make_it_more_polished"
      ]
    },

    "response_layers": {
      "layer_1_default": {
        "description": "Primary response shown by default.",
        "max_components": 4,
        "pattern": [
          "reaction_starter",
          "one_intelligence_fragment",
          "optional_one_overlay_fragment",
          "invitation_closer"
        ]
      },
      "layer_2_expandable_depth": {
        "description": "Optional depth shown only when user explicitly asks for more detail.",
        "max_components": 6,
        "pattern": [
          "reaction_starter",
          "one_intelligence_fragment",
          "optional_second_intelligence_fragment",
          "optional_one_overlay_fragment",
          "optional_upgrade_suggestion",
          "invitation_closer"
        ],
        "expand_when_any_of": [
          "asked_for_why",
          "asked_for_rating",
          "asked_for_improvement",
          "asked_for_options"
        ]
      }
    },

    "overlay_priority_and_limits": {
      "rule": "At most ONE overlay fragment in Layer 1. In Layer 2, at most ONE overlay fragment unless user is explicitly in options mode.",
      "overlay_priority_order": [
        "rating_mode (exclusive mode)",
        "occasion_overlay",
        "memory_reference_overlay",
        "polish_intentionality_overlay"
      ],
      "max_overlays_layer_1": 1,
      "max_overlays_layer_2": 1,
      "max_overlays_when_options_mode": 2,
      "overlay_stacking_disallowed_combinations": [
        "memory_reference_overlay + polish_intentionality_overlay in Layer 1",
        "occasion_overlay + memory_reference_overlay + polish_intentionality_overlay (never stack 3)"
      ]
    },

    "component_sources": {
      "reaction_starter": {
        "bank": "styling_personality.reaction_starters_bank_v1",
        "selection_rules": {
          "default_category": "warm_affirming",
          "if_emotion_vulnerable": "reassuring_support",
          "if_emotion_frustrated": "neutral_observational",
          "if_user_is_confident": "confidence_boost",
          "if_user_is_playful_and_not_vulnerable": "playful_light",
          "avoid_repetition_window_turns": 4
        }
      },

      "intelligence_fragment": {
        "banks_priority_order": [
          "styling_intelligence.silhouette_proportion_bank_v1",
          "styling_intelligence.color_harmony_bank_v1",
          "styling_intelligence.balance_focal_point_bank_v1",
          "styling_intelligence.polish_intentionality_bank_v1"
        ],
        "selection_rules": {
          "default_pick_one_bank_only": true,
          "bank_choice_hints": {
            "if_user_mentions_fit_shape_length": "silhouette_proportion_bank_v1",
            "if_user_mentions_color_match_palette": "color_harmony_bank_v1",
            "if_user_mentions_accessories_too_much_busy": "balance_focal_point_bank_v1",
            "if_user_says_something_missing_or_more_polished_or_expensive": "polish_intentionality_bank_v1"
          },
          "sentiment_category_choice": {
            "if_user_is_confident": "positive_*",
            "if_user_expresses_dissatisfaction": "constructive_*",
            "if_user_asks_be_honest": "constructive_*",
            "if_emotion_vulnerable": "positive_*"
          },
          "notes": [
            "Choose exactly one fragment for Layer 1.",
            "For Layer 2, add a second fragment only if user explicitly asks for detail."
          ]
        }
      },

      "occasion_overlay": {
        "bank": "styling_intelligence.occasion_overlays_bank_v1",
        "selection_rules": {
          "default_include": false,
          "include_when_any_of": [
            "user_mentions_occasion",
            "asked_for_outfit_for_event",
            "missing_context_details_and_user_provides_context"
          ],
          "max_fragments": 1,
          "pick_from": [
            "positive_fit",
            "soft_adjustments"
          ],
          "avoid": [
            "context_questions in the same turn as a long option list",
            "using more than one occasion overlay in Layer 1"
          ]
        }
      },

      "memory_reference_overlay": {
        "bank": "styling_intelligence.memory_reference_bank_v1",
        "selection_rules": {
          "default_include": false,
          "include_when_any_of": [
            "user_asks_for_personalization",
            "user_asks_what_suits_me",
            "asked_for_options_and_history_exists"
          ],
          "max_fragments": 1,
          "frequency_cap": {
            "max_per_conversation_window": 2,
            "window_turns": 8
          },
          "notes": [
            "Use neutral phrasing.",
            "Never use as a correction.",
            "Never use absolute language."
          ]
        }
      },

      "polish_intentionality_overlay": {
        "bank": "styling_intelligence.polish_intentionality_bank_v1",
        "selection_rules": {
          "default_include": false,
          "include_when_any_of": [
            "user_says_something_missing",
            "user_says_make_it_more_polished",
            "user_says_make_it_expensive",
            "asked_for_improvement"
          ],
          "max_fragments": 1,
          "pick_from": [
            "positive_polish",
            "constructive_unfinished",
            "finishing_touches",
            "effort_level_alignment"
          ],
          "notes": [
            "Prefer ONE finishing touch over multiple.",
            "Keep it gentle and supportive."
          ]
        }
      },

      "upgrade_suggestion": {
        "bank": "styling_intelligence.upgrade_suggestions_bank_v1",
        "selection_rules": {
          "default_include": false,
          "include_when_any_of": [
            "asked_for_improvement",
            "asked_for_options",
            "expressed_dissatisfaction"
          ],
          "exclude_when_any_of": [
            "expressed_confidence",
            "emotion_state_is_vulnerable"
          ],
          "count_rules": {
            "default": 1,
            "if_asked_for_options": 3,
            "max_without_user_request": 1
          },
          "options_bundle_rule": {
            "if_asked_for_options": "Provide 2 safe suggestions + 1 slightly bolder suggestion. Each suggestion must be one sentence."
          }
        }
      },

      "rating_mode": {
        "bank": "styling_intelligence.rating_mode_bank_v1",
        "selection_rules": {
          "exclusive_mode": true,
          "include_when_any_of": ["asked_for_rating"],
          "notes": [
            "Rating mode replaces normal assembly.",
            "If score <= 6, include exactly one gentle improvement path.",
            "Never use harsh language."
          ]
        }
      },

      "invitation_closer": {
        "bank": "styling_personality.invitation_closers_bank_v1",
        "selection_rules": {
          "default_category": "tweak_or_keep",
          "if_missing_context_details": "ask_context",
          "if_user_asked_for_options_or_nothing_to_wear": "offer_options",
          "if_user_needs_reassurance": "reassure_and_close",
          "if_user_requested_actionable_help": "next_step_actions",
          "pick_one_only": true,
          "avoid_multi_questions": true
        }
      }
    },

    "routing_rules": {
      "rating_mode_exclusive": {
        "when": ["asked_for_rating"],
        "do": [
          "use rating_mode.templates based on score band",
          "optionally append one invitation closer (pick_one_only)"
        ],
        "do_not": [
          "add other overlays",
          "add multiple intelligence fragments"
        ]
      },
      "when_user_says_outfit_is_perfect": {
        "rule": "Affirm confidence. Do not add constructive critique unless user explicitly asks for tweaks.",
        "assembly": [
          "reaction_starter (confidence_boost or warm_affirming)",
          "intelligence_fragment (positive_*)",
          "optional polish_intentionality_overlay (positive_polish only, max 1)",
          "invitation_closer (reassure_and_close OR tweak_or_keep)"
        ],
        "upgrade_suggestion_allowed": false,
        "memory_reference_allowed": true
      },
      "when_user_says_is_this_too_much": {
        "rule": "Reassure first. Offer optional simplification if requested.",
        "layer_1": [
          "reaction_starter (reassuring_support or warm_affirming)",
          "intelligence_fragment (positive_*)",
          "invitation_closer (reassure_and_close)"
        ],
        "layer_2_if_requested": [
          "optional intelligence_fragment (constructive_competing_elements)",
          "optional upgrade_suggestion (balance_and_focal_point_moves)"
        ]
      },
      "when_user_says_nothing_to_wear": {
        "rule": "Offer to generate looks from wardrobe first; then ask vibe/occasion; then optional shopping.",
        "assembly": [
          "reaction_starter (reassuring_support)",
          "optional memory_reference_overlay (preference_recall_general, max 1)",
          "invitation_closer (offer_options OR ask_context)"
        ],
        "notes": [
          "No teasing. No implying user is impatient.",
          "Default action is generating outfit options."
        ]
      },
      "when_user_says_be_honest": {
        "rule": "Increase specificity, not harshness. Keep gentle.",
        "layer_1": [
          "reaction_starter (warm_affirming or neutral_observational)",
          "intelligence_fragment (constructive_* but softened)",
          "invitation_closer (tweak_or_keep)"
        ],
        "layer_2_optional": [
          "optional second intelligence_fragment (constructive_*)",
          "optional upgrade_suggestion (1 only unless asked for options)"
        ]
      }
    },

    "tone_compliance": {
      "must_apply": [
        "Emotion overrides from tone engine take priority over everything.",
        "Context caps take priority over generation defaults.",
        "Emoji usage must not exceed emoji_cap.",
        "Slang tokens must not exceed slang_tokens_max.",
        "Keep grammar clean always."
      ],
      "vulnerable_mode_enforcement": [
        "No slang.",
        "No humor beyond gentle warmth.",
        "No critique unless user explicitly asks.",
        "Offer a small next step or a choice."
      ]
    },

    "output_format_guidance": {
      "line_breaks": {
        "allowed": true,
        "guidance": "Use short line breaks for human rhythm. Avoid long blocks."
      },
      "bullets": {
        "allowed_when": ["layer_2_expandable_depth", "asked_for_options"],
        "max_bullets": 3,
        "guidance": "Keep bullets short and actionable."
      }
    },

    "acceptance_tests": {
      "read_aloud": "Assembled outputs should sound natural when read aloud.",
      "no_rudeness": "No assembled response should sound like a correction or put-down.",
      "no_overstacking": "Layer 1 should never exceed: 1 reaction + 1 intelligence + 1 overlay + 1 closer.",
      "user_autonomy": "If user chooses a plan, AHVI supports and offers reminders instead of pushing.",
      "confidence_protection": "If user expresses confidence, AHVI should not undercut it.",
      "rating_mode_correctness": "Rating mode must not accidentally attach unrelated critique or overlays."
    }
  }
}